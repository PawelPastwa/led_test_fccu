/dts-v1/;

#include <espressif/esp32s3/esp32s3_wroom_n8.dtsi>
#include "fccu_v2-pinctrl.dtsi"
#include <espressif/partitions_0x0_amp.dtsi>


/ {
	model = "Hydrogreen FCCU-V2 board";
	compatible = "hydrogreen,fccu_v2";

	aliases {
		i2c-0 = &i2c0;
		watchdog0 = &wdt0;
	//	uart-0 = &uart0;
		can = &twai;
		fan-pin = &fan0;
		fan-pwm = &fan_pwm0;
		fan-tacho = &fan_tacho0;
		main-valve-pin = &main_valve0;
		purge-valve-pin = &purge_valve0;
		adc-1 = &adc0;
		can-status-led = &can_led0;
		counter0 = &counter0;
		counter1 = &counter1;
		counter2 = &counter2;
		counter3 = &counter3;
		driver-enable = &driver_enable0;
		driver-pwm = &driver_pwm0;
	};

	chosen {
		zephyr,sram = &sram1;
//		zephyr,console = &uart0;
//		zephyr,shell-uart = &uart0;
		zephyr,console = &usb_serial;
		zephyr,shell-uart = &usb_serial;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,bt-hci = &esp32_bt_hci;
		zephyr,canbus = &twai;
	};

	buttons {
		compatible = "gpio-keys";

		button0: button_0 {
			gpios = <&gpio0 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "BOOT Button";
		};
	};

	status_leds {
		compatible = "gpio-leds";

		can_led0: can_led_0 {
//			gpios = <&gpio0 12 GPIO_ACTIVE_HIGH>; //oryginalny z pliku
			gpios = <&gpio1 16 GPIO_ACTIVE_HIGH>; //esp32s3 super mini
			label = "CAN status LED";
		};
	};

	gpio_outputs {
		compatible = "gpio-leds";

		fan0: fan_0 {
			gpios = <&gpio1 38 GPIO_ACTIVE_HIGH>;
			label = "fan on pin";
		};
		main_valve0: main_valve_0 {
			gpios = <&gpio1 46 GPIO_ACTIVE_HIGH>;
			label = "main valve on pin";
		};
		purge_valve0: purge_valve_0 {
			gpios = <&gpio1 45 GPIO_ACTIVE_HIGH>;
			label = "purge valve on pin";
		};
		driver_enable0: driver_enable_0 {
			gpios = <&gpio0 21 GPIO_ACTIVE_HIGH>;
			label = "driver enable pin";
		};
	};

	gpio_inputs {
		fan_tacho0: fan_tacho_0 {
			gpios = <&gpio1 36 GPIO_ACTIVE_HIGH>;
			label = "fan tacho";
		};
	};

	zephyr,user {
		io-channels = <&adc0 6>, <&adc0 7>, <&adc0 8>, <&adc0 9>, <&adc0 10>;
		button-onboard-gpios  = <&gpio0 1  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		button-external-gpios = <&gpio0 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
	};

	pwm_leds {
		compatible = "pwm-leds";

		fan_pwm0: fan_pwm_0 {
			pwms = <&ledc0 0 40000 0>;
		};
		driver_pwm0: driver_pwm_0 {
			pwms = <&ledc0 1 40000 0>;
		};
	};
};

&usb_serial {
	status = "okay";
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&i2c0 {
	clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c0_default>;
	pinctrl-names = "default";
	status = "okay";

	bme280_76: bme280@76 {
		compatible = "bosch,bme280";
		reg = <0x76>;
		status = "okay";
	};

	bme280_77: bme280@77 {
		compatible = "bosch,bme280";
		reg = <0x77>;
		status = "okay";
	};

	ads1015_48: ads1015@48 {
		compatible = "ti,ads1015";
		reg = <0x48>;
		label = "ADS1015_48";
		#io-channel-cells = <1>;
		#address-cells = <1>;
		#size-cells = <0>;
		status = "disabled";
	};

	ads1015_49: ads1015@49 {
		compatible = "ti,ads1015";
		reg = <0x49>;
		label = "ADS1015_49";
		#io-channel-cells = <1>;
		#address-cells = <1>;
		#size-cells = <0>;
		status = "disabled";
	};
};

&i2c1 {
	clock-frequency = <I2C_BITRATE_STANDARD>;
	pinctrl-0 = <&i2c1_default>;
	pinctrl-names = "default";
	status = "disabled";
};

&i2s0 {
	pinctrl-0 = <&i2s0_default>;
	pinctrl-names = "default";
	status = "disabled";
};

&i2s1 {
	pinctrl-0 = <&i2s1_default>;
	pinctrl-names = "default";
	status = "disabled";
};

&spi2 {
	status = "disabled";
};

&twai {
	pinctrl-0 = <&twai_default>;
	pinctrl-names = "default";
	bus-speed = <500000>;
	status = "okay";
};

&timer0 {
	status = "okay";
	counter0: counter {
		status = "okay";
	};
};

&timer1 {
	status = "okay";
	counter1: counter {
		status = "okay";
	};
};

&timer2 {
	status = "okay";
	counter2: counter {
		status = "okay";
	};
};

&timer3 {
	status = "okay";
	counter3: counter {
		status = "okay";
	};
};

&wdt0 {
	status = "okay";
};

&trng0 {
	status = "okay";
};

&esp32_bt_hci {
	status = "okay";
};

&wifi {
	status = "okay";
};

&adc0 {
	status = "okay";
	unit = <1>;
	#io-channel-cells = <1>;
	#address-cells = <1>;
	#size-cells = <0>;
	channel-count = <10>;

	channel@6 {
		reg = <6>;
		zephyr,gain = "ADC_GAIN_1_4";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
	channel@7 {
		reg = <7>;
		zephyr,gain = "ADC_GAIN_1_4";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
	channel@8 {
		reg = <8>;
		zephyr,gain = "ADC_GAIN_1_4";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
	channel@9 {
		reg = <9>;
		zephyr,gain = "ADC_GAIN_1_4";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
	channel@10 {
		reg = <10>;
		zephyr,gain = "ADC_GAIN_1_4";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
};

&ledc0 {
	status = "okay";
	pinctrl-0 = <&ledc0_default>;
	pinctrl-names = "default";
	#address-cells = <1>;
	#size-cells = <0>;

	channel@0 {
		reg = <0x0>;
		timer = <0>;
	};
	channel@1 {
		reg = <0x1>;
		timer = <1>;
	};
};